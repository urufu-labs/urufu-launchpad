# =============================================================================
# urufu labs — env template. Copy to .env (never committed) and fill values.
# =============================================================================
# Not every var is needed for every command:
#   pnpm dev:*                       → NEXT_PUBLIC_* + SEPOLIA_RPC_URL
#   pnpm contracts:rehearse:*        → SEPOLIA_RPC_URL
#   pnpm contracts:deploy:phase1     → DEV_PRIVATE_KEY + SEPOLIA_RPC_URL
#   pnpm contracts:verify:phase1     → ETHERSCAN_API_KEY
#   pnpm contracts:smoke:phase1      → all of the above + a funded wallet
# All addresses stay `null` in web/indexer until DeployPhase1 writes them into
# `contracts/deployment.<chain>.json` — the postDeploy script auto-syncs those
# values into web/src/lib/config.ts + indexer .env.
# =============================================================================

# ---- RPC endpoints ----------------------------------------------------------
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
MAINNET_RPC_URL=
BASE_RPC_URL=
BASE_SEPOLIA_RPC_URL=
# Robinhood Chain (Arbitrum L2, chain IDs 4663 / 46630). Public RPCs are rate-limited;
# recommend swapping to an Alchemy endpoint for production.
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com

# ---- Broadcast identity (NEVER commit) --------------------------------------
# Fund with ~0.5 ETH on Sepolia. Rotate to a multisig (see MULTISIG_ADMIN)
# post-broadcast; the deploy key should never be a long-term admin key.
DEV_PRIVATE_KEY=

# HandoffOwnership.s.sol transfers Router/Registry/factory ownership to this.
# Use a Safe multisig on the same chain.
MULTISIG_ADMIN=

# ---- Etherscan verification -------------------------------------------------
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# ---- DeployPhase1 knobs (all optional; sensible defaults in the script) -----
# ADMIN=
# TREASURY=
# REGISTRAR=
# ERC20_FEE_WEI=
# MODULE_ADDON_WEI=
# HOOK_ADDON_WEI=
# GOV_ADDON_WEI=

# ---- NameRegistry deploy (DeployNameRegistry.s.sol) -------------------------
# Both fall back to the deploying key if unset. Post-deploy, transfer owner to a
# 2-of-3 multisig; treasury is where future name-registration sweeps land.
# REGISTRY_OWNER=
# REGISTRY_TREASURY=

# ---- v4 hook deploy (DeployHooks.s.sol) -------------------------------------
# Per-chain v4 PoolManager addresses. Set the one matching --fork-url before running.
#   Sepolia:      0xE03A1074c86CFeDd5C142C4F04F1a1536e203543
#   Base Sepolia: 0x05e73354cfdd6745c338b50bcfdfa3aa6fa03408
#   Mainnet/Base: https://docs.uniswap.org/contracts/v4/deployments
#   Robinhood:    not yet published — email chain-developers-group@robinhood.com or
#                 check robinhoodchain.blockscout.com for the canonical Uniswap v4
#                 PoolManager on Robinhood Chain.
V4_POOL_MANAGER=
# ROBINHOOD_V4_POOL_MANAGER=
# ROBINHOOD_TESTNET_V4_POOL_MANAGER=
# PLATFORM=
# CREATOR=
# PLATFORM_BPS=100
# CREATOR_BPS=100
# ANTISNIPER_GATE_BLOCKS=5
# BUYBACK_TOKEN=
# BUYBACK_BPS=200

# ---- Graduator deploy (DeployGraduator.s.sol) -------------------------------
# One Graduator per chain, immutable (poolManager, defaultHook, fee, tickSpacing).
# Broadcast per chain, then owner of CurveFactory calls setGraduator(new).
# DEFAULT_HOOK=                     # usually MultiHookHost from DeployHooks
# GRADUATOR_FEE=3000                # 0.3%
# GRADUATOR_TICK_SPACING=60
# WIRE_INTO_FACTORY=0               # 1 = also call CurveFactory.setGraduator in-script
# CURVE_FACTORY=                    # optional; auto-read from deployment.<chainid>.json

# ---- Web + indexer address inputs ------------------------------------------
# The web app compiles addresses in from `web/src/lib/config.ts` (written by
# `tools/sync-addresses.mjs`) — it does NOT read these envs directly. The
# indexer (`indexer/ponder.config.ts`) does read them; they set which contracts
# Ponder subscribes to for the chain selected by INDEXER_CHAIN below.
NEXT_PUBLIC_NAME_REGISTRY_ADDRESS=
NEXT_PUBLIC_ROUTER_ADDRESS=
NEXT_PUBLIC_ERC20_FACTORY_ADDRESS=
NEXT_PUBLIC_ERC721A_FACTORY_ADDRESS=
NEXT_PUBLIC_ERC1155_FACTORY_ADDRESS=
NEXT_PUBLIC_CURVE_FACTORY_ADDRESS=
# v4 PoolManager for the chain — enables indexer's PoolManager.Swap subscription so the
# home page live-activity rail picks up post-graduation swaps. On mainnet you'll want a
# per-poolId filter (this subscription is chain-wide right now).
NEXT_PUBLIC_POOL_MANAGER_ADDRESS=
NEXT_PUBLIC_INDEXER_URL=http://localhost:42069
NEXT_PUBLIC_COMPILE_SERVICE_URL=http://localhost:3001
# Per-chain RPC overrides for wagmi transports. Optional — viem falls back to each
# chain's default RPC when unset. Recommend Alchemy for prod (Robinhood especially,
# public RPC is rate-limited).
# NEXT_PUBLIC_MAINNET_RPC_URL=
# NEXT_PUBLIC_SEPOLIA_RPC_URL=
# NEXT_PUBLIC_BASE_RPC_URL=
# NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=
# NEXT_PUBLIC_ROBINHOOD_RPC_URL=
# NEXT_PUBLIC_ROBINHOOD_TESTNET_RPC_URL=

# ---- Flywheel deploy (DeployFlywheel.s.sol) ---------------------------------
# Existing urufu gemu contracts on Base. See docs/references/ecosystem-contracts.md.
URU_TOKEN_ADDRESS=0xF018A077a59fD9a24e99B76D0a7d0780792eB1Ac
GEMU_NFT_ADDRESS=0xE9FfA2B7Dc3b7012A4E919DA293E663ddfbFec9A
# URU balance required for the "URU holder" fee-discount tier. Default 100,000 URU.
URU_THRESHOLD=100000000000000000000000
# Cooldown between FeeSplitter config changes (default 2 days).
SPLITTER_CONFIG_DELAY=172800
# Platform's bps of NFT secondary-royalty ETH (default 500 = 5%). Launchers keep the rest.
# Frozen at RoyaltyRouterFactory construction — can't rotate later.
ROYALTY_PLATFORM_BPS=500

# ---- Flywheel configuration (ConfigureFlywheel.s.sol) -----------------------
# Address that will trigger buybacks on UruBuybackVault (bot / EOA / multisig).
# KEEPER=
# Uniswap Universal Router the keeper is allowed to route swaps through.
#   Base mainnet:  0x6fF5693b99212Da76ad316178A184AB56D299b43
#   Base sepolia:  0x492E6456D9528771018DeB9E87ef7750EF184104
#   Ethereum:      0x66a9893cC07D91D95644AEDD05D03f95e1dBA8Af
#   Sepolia:       0x3A9D48AB9751398BbFa63ad67599Bb04e4BdF98b
# Always verify against Uniswap docs before setting on mainnet.
# SWAP_TARGET=
# Optional split overrides (must sum to 10 000). Defaults: 4000 / 3500 / 2500.
# URU_BUYBACK_BPS=4000
# NFT_REVENUE_BPS=3500
# TREASURY_BPS=2500

# ---- IPFS metadata (optional) ------------------------------------------------
# When NEXT_PUBLIC_PINATA_JWT is set, launched-token metadata (logo + description +
# socials) auto-pins to IPFS via Pinata. Without it, metadata stays in localStorage
# only — everything still works, just per-device instead of portable.
NEXT_PUBLIC_PINATA_JWT=
NEXT_PUBLIC_PINATA_GATEWAY=gateway.pinata.cloud

# ---- Indexer ----------------------------------------------------------------
# Which chain this indexer instance runs against. In prod, run one instance per chain
# with a matching INDEXER_CHAIN. Local dev leaves it as sepolia.
INDEXER_CHAIN=sepolia
# Per-chain deploy block of the FIRST contract in the stack (Router usually) so Ponder
# doesn't rescan the whole chain. Set the one matching INDEXER_CHAIN before starting.
PONDER_START_BLOCK_SEPOLIA=6000000
# PONDER_START_BLOCK_MAINNET=
# PONDER_START_BLOCK_BASE=
# PONDER_START_BLOCK_BASE_SEPOLIA=
# PONDER_START_BLOCK_ROBINHOOD=
# PONDER_START_BLOCK_ROBINHOOD_TESTNET=

# ---- Compile service --------------------------------------------------------
PORT=3001
